# Локальный запуск
HOST=127.0.0.1
PORT=8000
VAS_OPEN_BROWSER=1

# Сессии
VAS_SESSION_HOURS=12
VAS_SESSION_COOKIE=vas_session
VAS_COOKIE_SECURE=0

# Учитывать X-Forwarded-For только за доверенным reverse proxy
VAS_TRUST_PROXY=0

# По умолчанию CORS не требуется: фронтенд и API работают с одного адреса.
# Если появится отдельный фронтенд, перечислить точные origin через запятую.
VAS_CORS_ORIGINS=
VAS_MAX_UPLOAD_MB=20

# Необязательно: отдельный путь к SQLite на переходном этапе
# VAS_DB_PATH=/var/lib/vas-report/data.db

# Только для неинтерактивного первоначального создания администратора.
# После команды переменную удалить из окружения.
# VAS_ADMIN_PASSWORD=
